# ═══════════════════════════════════════════════════════════════════
# Local development overrides — copy this file to:
#     application-local.properties
# (which is gitignored) and fill in real values for your machine.
#
# Then run with:  --spring.profiles.active=local
# or set:         SPRING_PROFILES_ACTIVE=local
# ═══════════════════════════════════════════════════════════════════

# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-64-character-hex-string

# Leave blank if your local MySQL root user has no password
DB_USERNAME=root
DB_PASSWORD=

# Optional integrations — leave disabled for local dev
TWILIO_ACCOUNT_SID=YOUR_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN
TWILIO_PHONE_NUMBER=YOUR_PHONE_NUMBER

# Optional email notifications — leave unset to disable
#MAIL_HOST=smtp.gmail.com
#MAIL_PORT=587
#MAIL_USERNAME=
#MAIL_PASSWORD=

PHARMACY_EMAIL=support@medicarepharmacy.example
PHARMACY_PHONE=1800-PHARMA
PHARMACY_WHATSAPP=https://wa.me/919876543210
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
